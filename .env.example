PORT=4000

# UiPath Automation Cloud values for a connected deployment.
# The local hackathon demo runs without these values.
UIPATH_BASE_URL=https://cloud.uipath.com
# This is the account/organization logical name from the URL.
# Example: https://staging.uipath.com/hackathon26_1032/... -> hackathon26_1032
UIPATH_ORGANIZATION_NAME=
# This is the tenant segment from the URL.
# Example: /hackathon26_1032/DefaultTenant/maestro_ -> DefaultTenant
UIPATH_TENANT_NAME=
UIPATH_FOLDER_ID=
UIPATH_CASE_PROJECT_KEY=LogithonCargoSafety

# Personal Access Token path for hackathon testing.
# Create this from your UiPath profile and grant Maestro, Orchestrator,
# and Data Fabric scopes. Studio Web normally has no PAT scope because
# it is used through your browser login.
UIPATH_PAT=

# External Application OAuth alternative for a production integration.
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
UIPATH_WEBHOOK_SECRET=

# Optional if replacing the deterministic risk service with an LLM/vision model.
OPENAI_API_KEY=
